# Guest Tracker — environment variables
# Copy this file to .env and fill in values. Never commit .env.

# Port the Express staff app listens on (default: 3000)
PORT=3000

# Port the Express admin app listens on (default: 3001)
ADMIN_PORT=3001

# Optional: protect the public export endpoints (/api/export/json and /api/export/csv)
# When set, requests must include ?key=<value> or the header X-Api-Key: <value>
# Leave empty (or unset) to keep the endpoints open — e.g. for existing PowerBI connectors
# Example: EXPORT_API_KEY=change-me-to-a-long-random-string
EXPORT_API_KEY=
